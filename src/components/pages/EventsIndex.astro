---
import PageHero from '../PageHero.astro';
import EventCard from '../EventCard.astro';
import EventTipForm from '../EventTipForm.astro';
import EventCalendar from '../islands/EventCalendar.tsx';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n';
import type { EventListItem, EventTip } from '../../sanity/lib/api';

interface Props {
  events: EventListItem[];
  upcoming: EventListItem[];
  past: EventListItem[];
  tips: EventTip[];
  lang: Lang;
}
const { events, upcoming, past, tips, lang } = Astro.props;
const calEvents = events.map((e) => ({ title: e.title, slug: e.slug, startsAt: e.startsAt }));
---
<PageHero label={t(lang, 'home.calendarLabel')} title={t(lang, 'nav.events')} lead={t(lang, 'events.pageLead')} object="/hero-scoreboard.png" objectHover="/hero-scoreboard-break.png" objectAlt="" />

{events.length === 0 ? (
  <section class="mx-auto max-w-4xl px-4 py-16">
    <p class="text-muted">{t(lang, 'home.eventsSoon')}</p>
  </section>
) : (
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-10 lg:grid-cols-[1fr_22rem]">
      <!-- Bal oldal: rendezvények -->
      <div>
        <h2 class="mb-2 font-display text-2xl">{t(lang, 'events.upcomingHeading')}</h2>
        {upcoming.length ? upcoming.map((e) => <EventCard event={e} lang={lang} />) : <p class="py-6 text-muted">{t(lang, 'events.noUpcoming')}</p>}
        {past.length > 0 && (
          <>
            <h2 class="mb-2 mt-14 font-display text-2xl">{t(lang, 'events.pastHeading')}</h2>
            {past.map((e) => <EventCard event={e} lang={lang} />)}
          </>
        )}
      </div>

      <!-- Jobb oldal: naptár -->
      <aside class="self-start lg:sticky lg:top-24">
        <p class="mb-3 inline-flex items-center gap-2 pt-1 text-xs uppercase leading-[1.6] tracking-[0.2em] text-accent">
          <span class="h-px w-8 bg-accent"></span><span class="inline-block">{t(lang, 'events.monthViewEyebrow')}</span>
        </p>
        <EventCalendar events={calEvents} lang={lang} client:load />
      </aside>
    </div>
  </section>
)}

{tips.length > 0 && (
  <section class="mx-auto max-w-6xl px-4 pb-4">
    <p class="mb-3 inline-flex items-center gap-2 pt-1 text-xs uppercase leading-[1.6] tracking-[0.2em] text-accent">
      <span class="h-px w-8 bg-accent"></span><span class="inline-block">{t(lang, 'events.tipsEyebrow')}</span>
    </p>
    <h2 class="mb-6 font-display text-2xl">{t(lang, 'events.tipsTitle')}</h2>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {tips.map((tip) => (
        <article class="flex flex-col rounded-2xl border border-ink/10 bg-surface p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-accent hover:shadow-lg">
          <h3 class="font-display text-xl leading-tight">{tip.eventName}</h3>
          {tip.description && <p class="mt-2 flex-1 text-sm text-muted line-clamp-4">{tip.description}</p>}
          {tip.facebookUrl && (
            <a href={tip.facebookUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-1 self-start rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-ink transition hover:opacity-90">
              {t(lang, 'events.viewOnFacebook')} <span aria-hidden="true">↗</span>
            </a>
          )}
        </article>
      ))}
    </div>
  </section>
)}

<!-- Esemény-tipp beküldő űrlap (mindig látszik) -->
<EventTipForm />
