---
import PageHero from '../PageHero.astro';
import RichText from '../RichText.astro';
import ContactForm from '../ContactForm.astro';
import AnimatedText from '../AnimatedText.astro';
import { localized } from '../../i18n/content';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n';
import type { PageDoc } from '../../sanity/lib/api';

interface Props { page: PageDoc | null; lang: Lang }
const { page, lang } = Astro.props;

const title = localized(page, 'title', lang) ?? (lang === 'en' ? 'Association' : 'Egyesület');
const lead = localized(page, 'lead', lang);
const body = localized(page, 'body', lang);
---
<PageHero label={t(lang, 'association.label')} title={title} lead={lead} object="/hero-beer.png" objectHover="/hero-beer-break.png" objectAlt="" />
<div class="mx-auto max-w-3xl px-4 py-12">
  {body ? <RichText value={body} /> : <p class="text-muted">{t(lang, 'association.placeholder')}</p>}
</div>

<section class="bg-ink text-surface">
  <div class="mx-auto max-w-3xl px-4 py-16">
    <p class="mb-2 inline-flex items-center gap-2 pt-1 text-xs uppercase leading-[1.6] tracking-[0.2em] text-accent">
      <span class="h-px w-8 bg-accent"></span><span class="inline-block">{t(lang, 'association.writeToUsEyebrow')}</span>
    </p>
    <h2 class="font-display text-3xl md:text-5xl leading-[0.95]"><AnimatedText text={t(lang, 'association.contactTitle')} /></h2>
    <p class="mt-3 max-w-xl text-surface/75">{t(lang, 'association.contactLead')}</p>
    <div class="mt-8 [&_input]:bg-surface [&_textarea]:bg-surface [&_input]:text-ink [&_textarea]:text-ink">
      <ContactForm dept="media" />
    </div>
  </div>
</section>
