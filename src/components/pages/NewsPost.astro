---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RichText from '../RichText.astro';
import { urlForImage } from '../../sanity/lib/image';
import { localized } from '../../i18n/content';
import { localizedPath, type Lang } from '../../i18n';
import type { Post } from '../../sanity/lib/api';

interface Props { post: Post; lang: Lang }
const { post, lang } = Astro.props;
const date = new Date(post.publishedAt).toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' });
const coverUrl = post.cover ? urlForImage(post.cover).width(1200).height(630).fit('crop').url() : undefined;
const title = localized(post, 'title', lang);
const excerpt = localized(post, 'excerpt', lang);
const body = localized(post, 'body', lang);

// Per-cikk SEO-felülírás (ha a szerkesztő kitöltötte), különben automatikus értékek.
const seoTitle = post.seo?.metaTitle || title;
const seoDescription = post.seo?.metaDescription || excerpt;
const seoImage = post.seo?.shareImage
  ? urlForImage(post.seo.shareImage).width(1200).height(630).fit('crop').url()
  : coverUrl;

// schema.org Article strukturált adat.
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  datePublished: post.publishedAt,
  ...(post.author ? { author: { '@type': 'Person', name: post.author } } : {}),
  ...(coverUrl ? { image: [coverUrl] } : {}),
  ...(excerpt ? { description: excerpt } : {}),
  publisher: { '@type': 'Organization', name: 'Slam Poetry Magyarország' },
  mainEntityOfPage: new URL(localizedPath(`/hirek/${post.slug}`, lang), Astro.site).href,
};
---
<BaseLayout title={seoTitle} description={seoDescription} image={seoImage} ogType="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleJsonLd)} />
  <article>
    <header class="bg-ink text-surface">
      <div class="mx-auto max-w-3xl px-4 py-16">
        <p class="text-xs uppercase tracking-[0.2em] text-accent">{date}{post.author ? ` · ${post.author}` : ''}</p>
        <h1 class="mt-3 font-display text-4xl md:text-6xl leading-[0.95]">{title}</h1>
      </div>
    </header>
    {post.cover && (
      <img src={urlForImage(post.cover).width(1200).url()} alt={title} class="mx-auto max-w-4xl w-full px-4 -mt-8 rounded-lg" />
    )}
    <div class="mx-auto max-w-3xl px-4 py-12">
      <RichText value={body} />
    </div>
  </article>
</BaseLayout>
