---
import { urlForImage } from '../../sanity/lib/image';
const { node } = Astro.props;
const url = node?.asset ? urlForImage(node).width(1200).fit('max').url() : null;
---
{url && (
  <figure class="my-8 not-prose">
    <img src={url} alt={node.alt ?? ''} class="w-full rounded-xl" loading="lazy" />
    {node.caption && <figcaption class="mt-2 text-center text-sm text-muted">{node.caption}</figcaption>}
  </figure>
)}
