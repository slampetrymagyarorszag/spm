---
import { urlForImage } from '../sanity/lib/image';
import { localized } from '../i18n/content';
import { localizedPath, type Lang } from '../i18n';
import type { PostListItem } from '../sanity/lib/api';
interface Props { post: PostListItem; lang?: Lang }
const { post, lang = 'hu' } = Astro.props;
const date = new Date(post.publishedAt).toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' });
const title = localized(post, 'title', lang);
const excerpt = localized(post, 'excerpt', lang);
---
<a href={localizedPath(`/hirek/${post.slug}`, lang)} class="group block">
  <div class="aspect-[16/10] overflow-hidden rounded-lg bg-ink/5">
    {post.cover && <img src={urlForImage(post.cover).width(640).height(400).url()} alt={title} loading="lazy" decoding="async" width="640" height="400" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />}
  </div>
  <p class="mt-3 text-xs uppercase tracking-wide text-muted">{date}</p>
  <h3 class="mt-1 font-display text-xl leading-tight group-hover:text-accent">{title}</h3>
  {excerpt && <p class="mt-1 text-sm text-muted line-clamp-2">{excerpt}</p>}
</a>
