---
// „Ez te vagy?" — a slammer a saját profiljáról módosítást kérhet (bio, linkek, új fotó),
// vagy jelezheti, hogy ne szerepeljen az oldalon. A /api/slammer-edit végpontra megy,
// és a Studióban várja az elbírálást.
import { t } from '../i18n/ui';
import { getLangFromUrl, type Lang } from '../i18n';
interface Props { slammerName: string; slammerSlug: string }
const { slammerName, slammerSlug } = Astro.props;
const lang: Lang = getLangFromUrl(Astro.url);
---
<section class="mx-auto max-w-6xl px-4 pb-16">
  <div class="rounded-2xl border border-ink/10 bg-ink/[0.03] p-5 md:p-6">
    <button type="button" class="se-toggle flex w-full items-center justify-between gap-4 text-left" aria-expanded="false" aria-controls={`se-panel-${slammerSlug}`}>
      <span>
        <span class="block font-display text-lg leading-tight">{t(lang, 'slammers.editToggleTitle')}</span>
        <span class="mt-1 block text-sm text-muted">{t(lang, 'slammers.editToggleLead')}</span>
      </span>
      <span class="se-chevron shrink-0 text-accent transition-transform" aria-hidden="true">▾</span>
    </button>

    <div id={`se-panel-${slammerSlug}`} class="se-panel mt-5 hidden">
      <form class="js-se-form grid gap-4" aria-label={t(lang, 'slammers.editFormAriaLabel')}>
        <input type="hidden" name="slammerSlug" value={slammerSlug} />
        <input type="hidden" name="slammerName" value={slammerName} />

        <!-- Hangsúlyos: aktív slammer jelölés (ez vezérli a Slammerek oldal „Aktív” csoportját) -->
        <label class="flex items-start gap-3 rounded-xl border-2 border-accent bg-accent/10 p-4">
          <input type="checkbox" name="activeSlammer" value="1" class="mt-0.5 h-5 w-5 accent-[var(--color-accent)]" />
          <span>
            <span class="block font-display text-base leading-tight">{t(lang, 'slammers.activeSelfLabel')}</span>
            <span class="mt-1 block text-sm text-muted">{t(lang, 'slammers.activeSelfLead')}</span>
          </span>
        </label>

        <div>
          <label class="mb-1 block text-sm text-muted" for="se-bio">{t(lang, 'slammers.editBioLabel')}</label>
          <textarea id="se-bio" name="bioChange" rows="4" class="w-full rounded-lg border border-ink/15 px-4 py-3 outline-none focus:border-accent" placeholder={t(lang, 'slammers.editBioPlaceholder')}></textarea>
        </div>
        <div>
          <label class="mb-1 block text-sm text-muted" for="se-links">{t(lang, 'slammers.editLinksLabel')}</label>
          <textarea id="se-links" name="linksChange" rows="2" class="w-full rounded-lg border border-ink/15 px-4 py-3 outline-none focus:border-accent" placeholder={t(lang, 'slammers.editLinksPlaceholder')}></textarea>
        </div>
        <div>
          <label class="mb-1 block text-sm text-muted" for="se-photo">{t(lang, 'slammers.editPhotoLabel')} <span class="text-ink/40">({t(lang, 'form.optionalMax8mb')})</span></label>
          <input id="se-photo" type="file" name="photo" accept="image/*" class="w-full rounded-lg border border-ink/15 px-4 py-2.5 text-sm file:mr-3 file:rounded-md file:border-0 file:bg-accent file:px-3 file:py-1.5 file:font-semibold file:text-ink" />
        </div>
        <label class="flex items-start gap-3 text-sm">
          <input type="checkbox" name="removeRequest" value="1" class="mt-1 h-4 w-4 accent-[var(--color-accent)]" />
          <span set:html={t(lang, 'slammers.removeRequestText')} />
        </label>
        <div>
          <label class="mb-1 block text-sm text-muted" for="se-email">{t(lang, 'form.email')} <span class="text-ink/40">({t(lang, 'form.optionalIfReply')})</span></label>
          <input id="se-email" type="email" name="email" class="w-full rounded-lg border border-ink/15 px-4 py-3 outline-none focus:border-accent" />
        </div>

        <!-- honeypot -->
        <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

        <div class="flex items-center gap-3">
          <button type="submit" class="rounded-lg bg-accent px-5 py-3 font-semibold text-ink transition hover:opacity-90">{t(lang, 'slammers.submitEditRequest')}</button>
          <p class="js-se-status text-sm" role="status" aria-live="polite" data-sending={t(lang, 'form.statusSending')} data-ok={t(lang, 'form.successEdit')} data-err={t(lang, 'form.statusError')} data-neterr={t(lang, 'form.statusNetworkError')}></p>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.se-toggle').forEach((node) => {
    const btn = node as HTMLButtonElement;
    const panel = btn.parentElement?.querySelector('.se-panel') as HTMLElement | null;
    const chev = btn.querySelector('.se-chevron') as HTMLElement | null;
    if (!panel) return;
    btn.addEventListener('click', () => {
      const open = panel.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (chev) chev.style.transform = open ? 'rotate(180deg)' : '';
    });
  });

  document.querySelectorAll('form.js-se-form').forEach((node) => {
    const f = node as HTMLFormElement;
    if (f.dataset.wired) return;
    f.dataset.wired = '1';
    const status = f.querySelector('.js-se-status') as HTMLElement;
    f.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = f.querySelector('button[type=submit]') as HTMLButtonElement;
      btn.disabled = true;
      status.textContent = status.dataset.sending ?? 'Küldés…';
      status.style.color = '';
      try {
        const res = await fetch('/api/slammer-edit', { method: 'POST', body: new FormData(f) });
        const json = await res.json();
        if (res.ok && json.ok) {
          status.textContent = status.dataset.ok ?? 'Köszönjük! Átnézzük a kérésed.';
          status.style.color = '#16a34a';
          f.reset();
        } else {
          status.textContent = json.error ?? status.dataset.err ?? 'Hiba történt.';
          status.style.color = '#dc2626';
        }
      } catch {
        status.textContent = status.dataset.neterr ?? 'Hálózati hiba. Próbáld újra.';
        status.style.color = '#dc2626';
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
