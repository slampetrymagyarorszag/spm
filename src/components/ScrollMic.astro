---
// Görgetést követő, 360°-ban pörgő 3D mikrofon (frame-szekvencia scroll-scrub).
// A képkockák a /mic-frames/ mappában, a darabszám a /mic-frames/manifest.json-ban.
// CANVAS-alapú rajzolás: a képkockákat előre betöltjük ÉS dekódoljuk, majd minden
// frame-váltásnál ctx.drawImage-zsel rajzolunk — így nincs JPEG-újradekódolás a fő
// szálon görgetés közben (sokkal simább). prefers-reduced-motion esetén statikus.
---
<canvas id="scroll-mic" class="scroll-mic" aria-hidden="true"></canvas>
<style>
  .scroll-mic {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: 46vw;
    max-width: 660px;
    pointer-events: none;
    mix-blend-mode: screen;
    opacity: 0;
    transition: opacity 0.45s ease;
    z-index: 5;
    -webkit-mask-image: radial-gradient(60% 56% at 60% 50%, #000 20%, rgba(0,0,0,0.35) 60%, transparent 88%);
    mask-image: radial-gradient(60% 56% at 60% 50%, #000 20%, rgba(0,0,0,0.35) 60%, transparent 88%);
  }
  /* Mobilon is megjelenik a görgő mikrofon — de diszkréten (a JS halványítja),
     a jobb szélre húzva, hogy ne menjen a szöveg olvashatóságának rovására. */
  @media (max-width: 767px) {
    /* Kisebb, feljebb húzott akcentus — a hero jobb oldalán marad, nem lóg az alatta
       lévő (világos) szekcióba, és nem rontja az olvashatóságot. */
    .scroll-mic { width: 62vw; height: 72vh; }
  }
</style>
<script>
  (async () => {
    const canvas = document.getElementById('scroll-mic') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let count = 0;
    let ext = 'jpg';
    try {
      const m = await (await fetch('/mic-frames/manifest.json')).json();
      count = m.count;
      ext = m.ext ?? 'jpg';
    } catch {
      return;
    }
    if (!count) return;

    const pad = (n: number) => String(n).padStart(3, '0');
    const srcFor = (i: number) => `/mic-frames/frame_${pad(i + 1)}.${ext}`;

    // Képkockák előtöltése ÉS dekódolása (a dekódolás a lényeg a simasághoz).
    const imgs: HTMLImageElement[] = [];
    const ready: boolean[] = new Array(count).fill(false);
    for (let i = 0; i < count; i++) {
      const im = new Image();
      im.decoding = 'async';
      im.src = srcFor(i);
      const idx = i;
      im.decode?.().then(() => { ready[idx] = true; }).catch(() => { ready[idx] = true; });
      im.addEventListener('load', () => { ready[idx] = true; });
      imgs.push(im);
    }

    const darks = Array.from(document.querySelectorAll('[data-mic-dark]'));

    // Mobilon a mikrofon halványabb (háttér-akcentus, nem dominál) — az olvashatóságért.
    const mqMobile = window.matchMedia('(max-width: 767px)');
    const onOpacity = () => (mqMobile.matches ? '0.32' : '1');

    // A canvas belső felbontása a megjelenített mérethez + devicePixelRatio.
    function sizeCanvas() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const r = canvas.getBoundingClientRect();
      canvas.width = Math.max(1, Math.round(r.width * dpr));
      canvas.height = Math.max(1, Math.round(r.height * dpr));
    }

    function draw(idx: number) {
      const im = imgs[idx];
      if (!im || !ready[idx] || !im.naturalWidth) return;
      const cw = canvas.width, ch = canvas.height;
      const iw = im.naturalWidth, ih = im.naturalHeight;
      const scale = Math.min(cw / iw, ch / ih);
      const dw = iw * scale, dh = ih * scale;
      const dx = cw - dw;          // jobbra igazítva
      const dy = (ch - dh) / 2;    // függőlegesen középre
      ctx.clearRect(0, 0, cw, ch);
      ctx.drawImage(im, dx, dy, dw, dh);
    }

    function frameForScroll(): number {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const p = max > 0 ? Math.min(Math.max(window.scrollY / max, 0), 1) : 0;
      return Math.round(p * (count - 1));
    }

    function darkVisible(): boolean {
      const vh = window.innerHeight;
      return darks.some((d) => {
        const r = d.getBoundingClientRect();
        return r.top < vh * 0.85 && r.bottom > vh * 0.15;
      });
    }

    let raf = 0;
    let lastIdx = -1;
    function update() {
      raf = 0;
      const idx = reduce ? 0 : frameForScroll();
      if (idx !== lastIdx) {
        draw(idx);
        lastIdx = idx;
      }
      canvas.style.opacity = darkVisible() ? onOpacity() : '0';
    }
    function onScroll() {
      if (!raf) raf = requestAnimationFrame(update);
    }
    function onResize() {
      sizeCanvas();
      lastIdx = -1; // kényszerített újrarajzolás az új mérettel
      onScroll();
    }

    // Ha a 0. kocka késik, rajzoljuk ki amint kész.
    if (imgs[0]) imgs[0].decode?.().then(() => { lastIdx = -1; update(); }).catch(() => {});

    sizeCanvas();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });
    update();
  })();
</script>
