---
// Mobil „vissza a tetejére" gomb. Csak kis kijelzőn (lg alatt), görgetés után jelenik
// meg; a home indicator fölött marad (safe-area). Hosszú oldalakon (slammerek,
// médiatár, hírek, profilok) sokat segít.
import { getLangFromUrl } from '../i18n';
const lang = getLangFromUrl(Astro.url);
const label = lang === 'en' ? 'Back to top' : 'Vissza a tetejére';
---
<button id="back-to-top" type="button" aria-label={label} title={label} class="back-to-top">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
</button>
<style>
  .back-to-top {
    position: fixed;
    right: 1.25rem;
    bottom: calc(1.25rem + env(safe-area-inset-bottom, 0px));
    z-index: 40;
    display: grid;
    place-items: center;
    height: 3rem;
    width: 3rem;
    border-radius: 9999px;
    background: var(--color-accent);
    color: var(--color-ink);
    box-shadow: 0 10px 30px -8px rgba(0, 0, 0, 0.5);
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .back-to-top.show {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  /* Csak kis kijelzőn (lg alatt) — desktopon nincs rá szükség. */
  @media (min-width: 1024px) {
    .back-to-top { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .back-to-top { transition: opacity 0.25s ease; transform: none; }
  }
</style>
<script>
  const btn = document.getElementById('back-to-top');
  if (btn) {
    const onScroll = () => btn.classList.toggle('show', window.scrollY > 600);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
    btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }
</script>
