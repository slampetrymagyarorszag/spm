---
// Karakterenkent animalt szoveg (hoverre staggered emelkedes), tiszta CSS-sel.
// A szavakat egyben tartja (inline-block .anim-word), igy a sortores CSAK a szavak kozott
// tortenhet -> nincs csunya szo-kozbeni tores. A stagger a teljes szovegen vegigfut.
interface Props { text: string; class?: string }
const { text, class: className = '' } = Astro.props;
const words = text.split(' ');
let i = -1;
const wordChars = words.map((word) => [...word].map((ch) => ({ ch, idx: ++i })));
---
<span class={`anim-text ${className}`} aria-label={text}>
  {wordChars.map((chars, wi) => (
    <>
      <span class="anim-word">
        {chars.map(({ ch, idx }) => (
          <span class="anim-char" aria-hidden="true" style={`--i:${idx}`}>{ch}</span>
        ))}
      </span>
      {wi < wordChars.length - 1 ? ' ' : ''}
    </>
  ))}
</span>
