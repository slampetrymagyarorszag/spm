---
import { t } from '../i18n/ui';
import { getLangFromUrl, type Lang } from '../i18n';
interface Props { eventSlug: string; deadline?: string }
const { eventSlug, deadline } = Astro.props;
const lang: Lang = getLangFromUrl(Astro.url);
---
<div class="my-8 rounded-lg border border-accent/40 bg-accent/5 p-5">
  <h2 class="font-display text-xl">{t(lang, 'registration.heading')}</h2>
  {deadline && <p class="mt-1 text-sm text-muted">{t(lang, 'registration.deadline')}: {new Date(deadline).toLocaleDateString(lang === 'hu' ? 'hu-HU' : 'en-GB')}</p>}
  <form id="reg-form" class="mt-4 grid gap-3" aria-label={t(lang, 'registration.formAriaLabel')} data-event={eventSlug}>
    <input type="text" name="name" placeholder={t(lang, 'registration.namePlaceholder')} aria-label={t(lang, 'registration.namePlaceholder')} required class="rounded-lg border border-ink/15 px-4 py-3" />
    <input type="email" name="email" placeholder={t(lang, 'registration.emailPlaceholder')} aria-label={t(lang, 'registration.emailPlaceholder')} required class="rounded-lg border border-ink/15 px-4 py-3" />
    <input type="tel" name="phone" placeholder={t(lang, 'registration.phonePlaceholder')} aria-label={t(lang, 'registration.phoneAriaLabel')} class="rounded-lg border border-ink/15 px-4 py-3" />
    <textarea name="message" rows="4" placeholder={t(lang, 'registration.messagePlaceholder')} aria-label={t(lang, 'registration.messageAriaLabel')} required class="rounded-lg border border-ink/15 px-4 py-3"></textarea>
    <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
    <button type="submit" class="rounded-lg bg-accent px-5 py-3 font-semibold text-ink hover:opacity-90">{t(lang, 'registration.submit')}</button>
    <p id="reg-status" class="text-sm" role="status" aria-live="polite" data-sending={t(lang, 'form.statusSending')} data-ok={t(lang, 'form.successRegistration')} data-err={t(lang, 'form.statusError')} data-neterr={t(lang, 'form.statusNetworkError')}></p>
  </form>
</div>
<script>
  const form = document.getElementById('reg-form') as HTMLFormElement | null;
  const status = document.getElementById('reg-status');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !status) return;
    const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
    btn.disabled = true; status.textContent = status.dataset.sending ?? 'Küldés…'; status.style.color = '';
    const payload = { ...Object.fromEntries(new FormData(form).entries()), eventSlug: form.dataset.event };
    try {
      const res = await fetch('/api/registration', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      const json = await res.json();
      if (res.ok && json.ok) { status.textContent = status.dataset.ok ?? 'Köszönjük a jelentkezést!'; status.style.color = 'green'; form.reset(); }
      else { status.textContent = json.error ?? status.dataset.err ?? 'Hiba történt.'; status.style.color = 'crimson'; }
    } catch { status.textContent = status.dataset.neterr ?? 'Hálózati hiba. Próbáld újra.'; status.style.color = 'crimson'; }
    finally { btn.disabled = false; }
  });
</script>
