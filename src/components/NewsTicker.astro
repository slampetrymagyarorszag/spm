---
import { urlForImage } from '../sanity/lib/image';
import { localized } from '../i18n/content';
import { localizedPath, type Lang } from '../i18n';
import type { PostListItem } from '../sanity/lib/api';
interface Props { posts: PostListItem[]; lang?: Lang }
const { posts, lang = 'hu' } = Astro.props;
// A zökkenőmentes loophoz duplikáljuk az elemeket.
const items = [...posts, ...posts];
const fmt = (d: string) =>
  new Date(d).toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' });
---
<div class="ticker group relative overflow-hidden">
  <!-- lágy szél-elhalványítás kétoldalt -->
  <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-surface to-transparent"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-surface to-transparent"></div>

  <div class="ticker-track flex w-max gap-6 px-4 group-hover:[animation-play-state:paused]">
    {items.map((post, idx) => (
      <a
        href={localizedPath(`/hirek/${post.slug}`, lang)}
        aria-hidden={idx >= posts.length ? 'true' : undefined}
        tabindex={idx >= posts.length ? -1 : undefined}
        class="group/card block w-[88vw] shrink-0 overflow-hidden rounded-2xl border border-ink/10 bg-surface shadow-sm transition hover:-translate-y-1 hover:border-accent hover:shadow-lg sm:w-[46vw] lg:w-[30rem]"
      >
        <div class="aspect-[16/9] overflow-hidden bg-ink/5">
          {post.cover && (
            <img
              src={urlForImage(post.cover).width(640).height(360).fit('crop').url()}
              alt=""
              loading="lazy"
              decoding="async"
              width="640"
              height="360"
              class="h-full w-full object-cover transition duration-500 group-hover/card:scale-105"
            />
          )}
        </div>
        <div class="p-5">
          <p class="text-xs uppercase tracking-wide text-muted">{fmt(post.publishedAt)}</p>
          <h3 class="mt-1 line-clamp-2 font-display text-2xl leading-tight transition-colors group-hover/card:text-accent">
            {localized(post, 'title', lang)}
          </h3>
        </div>
      </a>
    ))}
  </div>
</div>
<style>
  /* Jobbról balra, lassan; hoverre megáll, hogy legyen idő elolvasni. */
  @keyframes ticker-ltr {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .ticker-track { animation: ticker-ltr 90s linear infinite; }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; flex-wrap: wrap; }
  }
</style>
