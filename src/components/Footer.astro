---
import type { SiteSettings } from "../sanity/lib/api";
import { t } from "../i18n/ui";
import { localizedPath, type Lang } from "../i18n";
interface Props { settings: SiteSettings; lang: Lang; }
const { settings, lang } = Astro.props;
const s = settings.social ?? {};
const year = new Date().getFullYear();
const imp = settings.impressum ?? {};
const orgName = imp.orgName || 'Slam Poetry Magyarország Egyesület';

// A megadott alap-linkek; a Studio siteSettings.social felülírhatja őket.
const socials = [
  { key: "facebook", label: "Facebook", url: s.facebook || "https://www.facebook.com/SlamPoetryHungary" },
  { key: "instagram", label: "Instagram", url: s.instagram || "https://www.instagram.com/slampoetry_magyarorszag/" },
  { key: "youtube", label: "YouTube", url: s.youtube || "https://www.youtube.com/@slampoetrymagyarorsz" },
  { key: "tiktok", label: "TikTok", url: s.tiktok || "https://www.tiktok.com/@slampoetrymagyarorszag" },
].filter((x) => x.url);
---
<footer class="surface-dark bg-ink text-surface">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="flex flex-col items-start gap-8 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="font-display text-2xl leading-[0.85]">Slam Poetry<br /><span class="text-accent">Magyarország</span></p>
        {settings.contactEmail && (
          <a href={`mailto:${settings.contactEmail}`} class="mt-3 inline-block text-sm text-surface/70 hover:text-accent">{settings.contactEmail}</a>
        )}
      </div>

      <ul class="flex flex-wrap gap-3">
        {socials.map((soc) => (
          <li>
            <a
              href={soc.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={soc.label}
              class="group relative flex items-center gap-2 overflow-hidden rounded-full border border-surface/20 px-4 py-2.5 text-sm font-semibold transition-all duration-300 hover:-translate-y-0.5 hover:border-accent"
            >
              <span class="absolute inset-0 -z-0 translate-y-full bg-accent transition-transform duration-300 group-hover:translate-y-0"></span>
              <span class="relative z-10 flex items-center gap-2 transition-colors group-hover:text-ink">
                {soc.key === "facebook" && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.9h-2.34V22c4.78-.79 8.43-4.94 8.43-9.94Z"/></svg>
                )}
                {soc.key === "instagram" && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.62c-3.15 0-3.52.01-4.76.07-1.15.05-1.77.24-2.19.4-.55.21-.94.47-1.35.88-.41.41-.67.8-.88 1.35-.16.42-.35 1.04-.4 2.19-.06 1.24-.07 1.61-.07 4.76s.01 3.52.07 4.76c.05 1.15.24 1.77.4 2.19.21.55.47.94.88 1.35.41.41.8.67 1.35.88.42.16 1.04.35 2.19.4 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c1.15-.05 1.77-.24 2.19-.4.55-.21.94-.47 1.35-.88.41-.41.67-.8.88-1.35.16-.42.35-1.04.4-2.19.06-1.24.07-1.61.07-4.76s-.01-3.52-.07-4.76c-.05-1.15-.24-1.77-.4-2.19a3.6 3.6 0 0 0-.88-1.35 3.6 3.6 0 0 0-1.35-.88c-.42-.16-1.04-.35-2.19-.4-1.24-.06-1.61-.07-4.76-.07Zm0 2.76a5.3 5.3 0 1 1 0 10.6 5.3 5.3 0 0 1 0-10.6Zm0 1.62a3.68 3.68 0 1 0 0 7.36 3.68 3.68 0 0 0 0-7.36Zm5.5-2.9a1.24 1.24 0 1 1 0 2.48 1.24 1.24 0 0 1 0-2.48Z"/></svg>
                )}
                {soc.key === "youtube" && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.12-2.12C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.53A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.12 2.12c1.88.53 9.38.53 9.38.53s7.5 0 9.38-.53a3 3 0 0 0 2.12-2.12A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8ZM9.55 15.57V8.43L15.82 12l-6.27 3.57Z"/></svg>
                )}
                {soc.key === "tiktok" && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.6 5.82a4.28 4.28 0 0 1-1.05-2.82h-3.3v12.6a2.59 2.59 0 0 1-2.58 2.5 2.59 2.59 0 0 1-2.59-2.59 2.59 2.59 0 0 1 3.37-2.47V9.66a5.9 5.9 0 0 0-.78-.05A5.9 5.9 0 0 0 3.78 15.5a5.9 5.9 0 0 0 5.9 5.9 5.9 5.9 0 0 0 5.9-5.9V9.01a7.56 7.56 0 0 0 4.42 1.42V7.13a4.28 4.28 0 0 1-3.4-1.31Z"/></svg>
                )}
                {soc.label}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Impresszum -->
    <div class="mt-10 grid gap-6 border-t border-white/10 pt-8 text-sm text-surface/70 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <p class="mb-2 text-xs uppercase tracking-[0.2em] text-accent">{t(lang, 'footer.impressum')}</p>
        <p class="font-display text-surface">{orgName}</p>
        {imp.address && <p class="mt-1 whitespace-pre-line">{imp.address}</p>}
        {imp.taxNumber && <p class="mt-1 text-xs text-surface/50">{imp.taxNumber}</p>}
      </div>
      <div>
        <p class="mb-2 text-xs uppercase tracking-[0.2em] text-accent">{t(lang, 'footer.contact')}</p>
        {settings.contactEmail && <a href={`mailto:${settings.contactEmail}`} class="block hover:text-accent">{settings.contactEmail}</a>}
        <a href={localizedPath('/kapcsolat', lang)} class="mt-1 inline-block hover:text-accent">{t(lang, 'footer.getInTouch')}</a>
      </div>
      <div>
        <p class="mb-2 text-xs uppercase tracking-[0.2em] text-accent">{t(lang, 'footer.transparency')}</p>
        {imp.annualReportsUrl
          ? <a href={imp.annualReportsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 hover:text-accent">{t(lang, 'footer.annualReports')} ↗</a>
          : <span class="text-surface/40">{t(lang, 'footer.annualReportsSoon')}</span>}
      </div>
    </div>

    <p class="mt-8 text-xs text-muted">© {year} {orgName}</p>
  </div>
</footer>
