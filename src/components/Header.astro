---
import type { SiteSettings } from "../sanity/lib/api";
import ThemeToggle from "./ThemeToggle.astro";
interface Props { settings: SiteSettings; }
const { settings } = Astro.props;
const nav = settings.nav?.length ? settings.nav : [
  { label: "Mi az a slam?", href: "/mi-az-a-slam-poetry" },
  { label: "Események", href: "/esemenyek" },
  { label: "Slammerek", href: "/slammerek" },
  { label: "Hírek", href: "/hirek" },
  { label: "Médiatár", href: "/mediatar" },
  { label: "Egyesület", href: "/egyesulet" },
  { label: "Kapcsolat", href: "/kapcsolat" },
];
const s = settings.social ?? {};
const socials = [
  { key: "facebook", label: "Facebook", url: s.facebook || "https://www.facebook.com/SlamPoetryHungary" },
  { key: "instagram", label: "Instagram", url: s.instagram || "https://www.instagram.com/slampoetry_magyarorszag/" },
  { key: "youtube", label: "YouTube", url: s.youtube || "https://www.youtube.com/@slampoetrymagyarorsz" },
];
---
<header class="surface-dark sticky top-0 z-50 bg-ink text-surface">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <div class="flex items-center gap-4">
      <a href="/" class="flex items-center gap-3">
        {settings.logoUrl
          ? <img src={settings.logoUrl} alt={settings.title} class="h-10 w-auto" />
          : (
            /* Tartalék: a statikus public/logo.jpg fekete-fehér háttéren — a sötét fejlécen
               invertáljuk + "screen" keveréssel, így a fehér háttér eltűnik, a logó fehéren látszik. */
            <img src="/logo.jpg" alt={settings.title} class="h-10 w-auto invert mix-blend-screen" />
          )}
        <span class="font-display text-sm leading-[0.82] sm:text-base">
          <span class="block">Slam Poetry</span>
          <span class="block text-accent">Magyarország</span>
        </span>
      </a>

      <span class="hidden h-7 w-px bg-surface/20 lg:block"></span>
      <ul class="hidden items-center gap-1 lg:flex">
        {socials.map((soc) => (
          <li>
            <a
              href={soc.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={soc.label}
              class="flex h-8 w-8 items-center justify-center rounded-full text-surface/70 transition hover:bg-white/10 hover:text-accent"
            >
              {soc.key === "facebook" && (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.9h-2.34V22c4.78-.79 8.43-4.94 8.43-9.94Z"/></svg>
              )}
              {soc.key === "instagram" && (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.62c-3.15 0-3.52.01-4.76.07-1.15.05-1.77.24-2.19.4-.55.21-.94.47-1.35.88-.41.41-.67.8-.88 1.35-.16.42-.35 1.04-.4 2.19-.06 1.24-.07 1.61-.07 4.76s.01 3.52.07 4.76c.05 1.15.24 1.77.4 2.19.21.55.47.94.88 1.35.41.41.8.67 1.35.88.42.16 1.04.35 2.19.4 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c1.15-.05 1.77-.24 2.19-.4.55-.21.94-.47 1.35-.88.41-.41.67-.8.88-1.35.16-.42.35-1.04.4-2.19.06-1.24.07-1.61.07-4.76s-.01-3.52-.07-4.76c-.05-1.15-.24-1.77-.4-2.19a3.6 3.6 0 0 0-.88-1.35 3.6 3.6 0 0 0-1.35-.88c-.42-.16-1.04-.35-2.19-.4-1.24-.06-1.61-.07-4.76-.07Zm0 2.76a5.3 5.3 0 1 1 0 10.6 5.3 5.3 0 0 1 0-10.6Zm0 1.62a3.68 3.68 0 1 0 0 7.36 3.68 3.68 0 0 0 0-7.36Zm5.5-2.9a1.24 1.24 0 1 1 0 2.48 1.24 1.24 0 0 1 0-2.48Z"/></svg>
              )}
              {soc.key === "youtube" && (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.12-2.12C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.53A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.12 2.12c1.88.53 9.38.53 9.38.53s7.5 0 9.38-.53a3 3 0 0 0 2.12-2.12A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8ZM9.55 15.57V8.43L15.82 12l-6.27 3.57Z"/></svg>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="flex items-center gap-4">
      <ul class="hidden gap-5 md:flex">
        {nav.map((item) => (
          <li><a href={item.href} class="text-sm uppercase tracking-wide hover:text-accent">{item.label}</a></li>
        ))}
      </ul>
      <ThemeToggle />
    </div>
  </nav>
</header>
