---
// Világos/sötét téma-kapcsoló — csúszkás pill kapcsoló (sötétben hold balra,
// világosban nap jobbra). A villanásmentes téma-beállítást a BaseLayout fejlécében
// futó inline szkript végzi; ez csak vált + elment localStorage-ba.
---
<button
  type="button"
  class="theme-toggle"
  role="switch"
  aria-checked="true"
  aria-label="Világos vagy sötét téma váltása"
  title="Téma váltása"
>
  <span class="tt-track">
    <span class="tt-knob">
      <!-- Hold (sötét mód) -->
      <svg class="tt-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
      </svg>
      <!-- Nap (világos mód) -->
      <svg class="tt-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2"></path><path d="M12 20v2"></path>
        <path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path>
        <path d="M2 12h2"></path><path d="M20 12h2"></path>
        <path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
      </svg>
    </span>
  </span>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    padding: 0;
    background: none;
    border: 0;
    cursor: pointer;
    border-radius: 9999px;
    line-height: 0;
  }
  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .tt-track {
    position: relative;
    box-sizing: border-box;
    width: 56px;
    height: 28px;
    padding: 3px;
    border-radius: 9999px;
    border: 1px solid #27272a;        /* zinc-800 */
    background: #09090b;              /* zinc-950 */
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .tt-knob {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 9999px;
    background: #27272a;              /* zinc-800 */
    transform: translateX(0);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s ease;
  }
  .tt-knob svg { width: 14px; height: 14px; }
  .tt-moon { color: #ffffff; display: block; }
  .tt-sun  { color: #374151; display: none; }   /* gray-700 */

  /* Világos mód: a gomb átcsúszik jobbra, és nap-ikon jelenik meg. */
  :global(html.light) .tt-track { background: #ffffff; border-color: #e4e4e7; } /* zinc-200 */
  :global(html.light) .tt-knob  { transform: translateX(28px); background: #e5e7eb; } /* gray-200 */
  :global(html.light) .tt-moon  { display: none; }
  :global(html.light) .tt-sun   { display: block; }

  @media (prefers-reduced-motion: reduce) {
    .tt-track, .tt-knob { transition: none; }
  }
</style>

<script>
  document.querySelectorAll('.theme-toggle').forEach((b) => {
    const sync = () => b.setAttribute('aria-checked', document.documentElement.classList.contains('light') ? 'false' : 'true');
    sync();
    b.addEventListener('click', () => {
      const light = !document.documentElement.classList.contains('light');
      document.documentElement.classList.toggle('light', light);
      try { localStorage.setItem('theme', light ? 'light' : 'dark'); } catch (e) {}
      sync();
    });
  });
</script>
