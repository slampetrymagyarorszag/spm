---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getSiteSettings, type SiteSettings } from "../sanity/lib/api";
import { sanityClient } from "sanity:client";
import { getLangFromUrl, alternatePath, LOCALES, type Lang } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  /** OG/Twitter megosztó kép — abszolút URL vagy az oldal gyökeréhez relatív útvonal. */
  image?: string;
  /** OpenGraph típus: cikk-/profil-oldalaknál "article", egyébként "website". */
  ogType?: "website" | "article";
  /** Ha igaz, a keresőknek tiltjuk az indexelést (pl. hibaoldal). */
  noindex?: boolean;
}
const {
  title,
  description,
  image = "/og-default.jpg",
  ogType = "website",
  noindex = false,
} = Astro.props;

const settings: SiteSettings = (await getSiteSettings(sanityClient)) ?? { title: "Slam Poetry Magyarország" };
const pageTitle = title ? `${title} — ${settings.title}` : settings.title;

const SITE_DESCRIPTION =
  "A magyar slam poetry színtér élő központja: események, slammerek, hírek és médiatár — Slam Poetry Magyarország.";
const metaDescription = description || SITE_DESCRIPTION;

// Kanonikus és abszolút URL-ek a megfelelő megosztáshoz/indexeléshez.
// (Astro.site az astro.config-ban beállított nyilvános domain.)
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const lang: Lang = getLangFromUrl(Astro.url);
// hreflang alternatívák: ugyanaz az oldal minden nyelven (abszolút URL).
const hreflangs = LOCALES.map((l) => ({
  lang: l,
  href: new URL(alternatePath(Astro.url.pathname, l), Astro.site).href,
}));
const ogImage = new URL(image, Astro.site).href;

// A CMS-ben megadott alap accent szín felülírja a design-token alapértéket (a Tailwind
// `*-accent` utility-k a --color-accent változót használják). Esemény-oldalak ezt később
// szintén felülírhatják a saját poszter-színükre.
const bodyStyle = settings.accentColor ? `--color-accent: ${settings.accentColor}` : undefined;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Villanásmentes téma: ALAP a sötét; világos csak akkor, ha a felhasználó arra váltott.
      (function () {
        try {
          if (localStorage.getItem('theme') === 'light') document.documentElement.classList.add('light');
        } catch (e) {}
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonical} />
    {hreflangs.map((h) => <link rel="alternate" hreflang={h.lang} href={h.href} />)}
    <link rel="alternate" hreflang="x-default" href={hreflangs.find((h) => h.lang === 'hu')!.href} />
    <meta property="og:locale" content={lang === 'en' ? 'en_GB' : 'hu_HU'} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon / ikon -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#111111" />

    <!-- OpenGraph (Facebook, Messenger, LinkedIn) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={settings.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Per-oldal extra fej (pl. strukturált adat / JSON-LD) -->
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col" style={bodyStyle}>
    <Header settings={settings} lang={lang} />
    <main class="flex-1"><slot /></main>
    <Footer settings={settings} lang={lang} />
  </body>
</html>
