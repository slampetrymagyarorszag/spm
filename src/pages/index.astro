---
import BaseLayout from "../layouts/BaseLayout.astro";
import ScrollMic from "../components/ScrollMic.astro";
import SectionHeader from "../components/SectionHeader.astro";
import EventCard from "../components/EventCard.astro";
import NewsTicker from "../components/NewsTicker.astro";
import FeaturedSlammers from "../components/islands/FeaturedSlammers.tsx";
import { getEvents, getSlammers, getFeaturedSlammers, getPosts, getSiteSettings } from "../sanity/lib/api";
import { splitEvents } from "../sanity/lib/events";
import { urlForImage } from "../sanity/lib/image";
import { sanityClient } from "sanity:client";
import ChampionshipCta from "../components/ChampionshipCta.astro";
import MonthlyContestButton from "../components/MonthlyContestButton.astro";

const [events, slammers, featured, posts, settings] = await Promise.all([
  getEvents(sanityClient),
  getSlammers(sanityClient),
  getFeaturedSlammers(sanityClient),
  getPosts(sanityClient),
  getSiteSettings(sanityClient),
]);
const siteSettings = settings ?? { title: 'Slam Poetry Magyarország' };
const upcoming = splitEvents(events).upcoming.slice(0, 4);
// Kiemelt slammerek a CMS-ből (max 10); ha nincs kiemelt, az első néhány (név szerint).
const slammerSource = featured.length ? featured : slammers;
const featuredSlammers = slammerSource
  .filter((s) => s.photo)
  .slice(0, 10)
  .map((s) => ({
    name: s.name,
    slug: s.slug,
    hometown: s.hometown,
    photoUrl: s.photo ? urlForImage(s.photo).width(500).height(720).fit('crop').url() : undefined,
  }));
const latestPosts = posts.slice(0, 12);

const s = siteSettings.social ?? {};
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Slam Poetry Magyarország',
  url: Astro.site?.href ?? 'https://slampoetry.hu',
  logo: new URL('/og-default.jpg', Astro.site).href,
  sameAs: [s.facebook, s.instagram, s.youtube].filter(Boolean),
};
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Slam Poetry Magyarország',
  url: Astro.site?.href ?? 'https://slampoetry.hu',
};

// Szerkeszthető hero-szövegek (siteSettings.home), alapértékekkel.
const home = siteSettings.home ?? {};
const heroSticker = home.heroSticker || 'Élő közösség 2006 óta';
const heroTitle = home.heroTitle || 'Slam Poetry Magyarország';
const heroLead = home.heroLead || 'A magyar slam poetry színtér élő központja — események, slammerek, hírek és média egy helyen.';
const primaryCtaLabel = home.primaryCtaLabel || 'Közelgő események';
const primaryCtaHref = home.primaryCtaHref || '/esemenyek';
const secondaryCtaLabel = home.secondaryCtaLabel || 'Mi az a slam poetry?';
const secondaryCtaHref = home.secondaryCtaHref || '/mi-az-a-slam-poetry';
---
<BaseLayout>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify([orgJsonLd, siteJsonLd])} />
  <ScrollMic />
  <!-- Hero -->
  <section data-mic-dark class="relative overflow-hidden bg-ink text-surface">
    <div class="relative z-10 mx-auto max-w-6xl px-4 py-28 md:py-36">
      <span class="sticker mb-6">{heroSticker}</span>
      <h1 class="font-display text-6xl md:text-8xl leading-[0.9] max-w-3xl">{heroTitle}</h1>
      <p class="mt-5 max-w-xl text-lg text-surface/80">{heroLead}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={primaryCtaHref} class="rounded-lg bg-accent px-6 py-3 font-semibold text-ink hover:opacity-90">{primaryCtaLabel}</a>
        <a href={secondaryCtaHref} class="rounded-lg border border-surface/30 px-6 py-3 font-semibold hover:border-accent hover:text-accent">{secondaryCtaLabel}</a>
        <ChampionshipCta settings={siteSettings} />
        <MonthlyContestButton settings={siteSettings} />
      </div>
    </div>
  </section>

  <!-- Közelgő események -->
  <section class="mx-auto max-w-5xl px-4 py-16 md:py-20">
    <div class="flex items-end justify-between">
      <SectionHeader label="Naptár" title="Közelgő események" />
      <a href="/esemenyek" class="mb-10 hidden text-sm uppercase tracking-wide text-accent hover:underline sm:block">Összes esemény →</a>
    </div>
    {upcoming.length === 0 ? (
      <p class="text-muted">Hamarosan meghirdetjük a következő eseményeket.</p>
    ) : (
      <div>{upcoming.map((e) => <EventCard event={e} />)}</div>
    )}
  </section>

  <!-- Slammerek -->
  <section data-mic-dark class="bg-ink text-surface">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <div class="flex items-end justify-between">
        <SectionHeader label="A színtér arcai" title="Slammerek" />
        <a href="/slammerek" class="mb-10 hidden text-sm uppercase tracking-wide text-accent hover:underline sm:block">Összes slammer →</a>
      </div>
      {featuredSlammers.length === 0 ? (
        <p class="text-surface/60">Hamarosan feltöltjük a slammerek profiljait.</p>
      ) : (
        <FeaturedSlammers slammers={featuredSlammers} client:load />
      )}
    </div>
  </section>

  <!-- Friss hírek — folyamatosan futó szalag -->
  <section class="py-16 md:py-20">
    <div class="mx-auto mb-8 flex max-w-6xl items-end justify-between px-4">
      <SectionHeader label="Friss" title="Hírek" />
      <a href="/hirek" class="mb-10 hidden text-sm uppercase tracking-wide text-accent hover:underline sm:block">Összes hír →</a>
    </div>
    {latestPosts.length === 0 ? (
      <p class="mx-auto max-w-6xl px-4 text-muted">Hamarosan érkeznek az első hírek.</p>
    ) : (
      <NewsTicker posts={latestPosts} />
    )}
  </section>
</BaseLayout>
