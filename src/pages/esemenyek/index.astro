---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import EventCard from '../../components/EventCard.astro';
import EventTipForm from '../../components/EventTipForm.astro';
import EventCalendar from '../../components/islands/EventCalendar.tsx';
import { getEvents, getEventTips } from '../../sanity/lib/api';
import { splitEvents } from '../../sanity/lib/events';
import { sanityClient } from 'sanity:client';
const [events, tips] = await Promise.all([getEvents(sanityClient), getEventTips(sanityClient)]);
const { upcoming, past } = splitEvents(events);
const calEvents = events.map((e) => ({ title: e.title, slug: e.slug, startsAt: e.startsAt }));
---
<BaseLayout title="Események">
  <PageHero label="Naptár" title="Események" lead="Közelgő slam estek és versenyek." object="/hero-scoreboard.png" objectHover="/hero-scoreboard-break.png" objectAlt="" />

  {events.length === 0 ? (
    <section class="mx-auto max-w-4xl px-4 py-16">
      <p class="text-muted">Hamarosan meghirdetjük a következő eseményeket.</p>
    </section>
  ) : (
    <section class="mx-auto max-w-6xl px-4 py-16">
      <div class="grid gap-10 lg:grid-cols-[1fr_22rem]">
        <!-- Bal oldal: rendezvények -->
        <div>
          <h2 class="mb-2 font-display text-2xl">Közelgő</h2>
          {upcoming.length ? upcoming.map((e) => <EventCard event={e} />) : <p class="py-6 text-muted">Jelenleg nincs meghirdetett közelgő esemény.</p>}
          {past.length > 0 && (
            <>
              <h2 class="mb-2 mt-14 font-display text-2xl">Korábbi</h2>
              {past.map((e) => <EventCard event={e} />)}
            </>
          )}
        </div>

        <!-- Jobb oldal: naptár -->
        <aside class="self-start lg:sticky lg:top-24">
          <p class="mb-3 inline-flex items-center gap-2 pt-1 text-xs uppercase leading-[1.6] tracking-[0.2em] text-accent">
            <span class="h-px w-8 bg-accent"></span><span class="inline-block">Havi nézet</span>
          </p>
          <EventCalendar events={calEvents} client:load />
        </aside>
      </div>
    </section>
  )}

  {tips.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 pb-4">
      <p class="mb-3 inline-flex items-center gap-2 pt-1 text-xs uppercase leading-[1.6] tracking-[0.2em] text-accent">
        <span class="h-px w-8 bg-accent"></span><span class="inline-block">Közösségi tippek</span>
      </p>
      <h2 class="mb-6 font-display text-2xl">Tőletek érkezett</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {tips.map((t) => (
          <article class="flex flex-col rounded-2xl border border-ink/10 bg-surface p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-accent hover:shadow-lg">
            <h3 class="font-display text-xl leading-tight">{t.eventName}</h3>
            {t.description && <p class="mt-2 flex-1 text-sm text-muted line-clamp-4">{t.description}</p>}
            {t.facebookUrl && (
              <a href={t.facebookUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-1 self-start rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-ink transition hover:opacity-90">
                Megnézem a Facebookon <span aria-hidden="true">↗</span>
              </a>
            )}
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Esemény-tipp beküldő űrlap (mindig látszik) -->
  <EventTipForm />
</BaseLayout>
