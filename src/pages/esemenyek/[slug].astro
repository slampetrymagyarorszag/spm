---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RichText from '../../components/RichText.astro';
import EventNeonCard from '../../components/EventNeonCard.astro';
import RegistrationForm from '../../components/RegistrationForm.astro';
import { urlForImage } from '../../sanity/lib/image';
import { getEvents, getEventBySlug } from '../../sanity/lib/api';
import { sanityClient } from 'sanity:client';
export async function getStaticPaths() {
  const events = await getEvents(sanityClient);
  return events.map((e) => ({ params: { slug: e.slug } }));
}
const { slug } = Astro.params;
const ev = await getEventBySlug(sanityClient, slug!);
if (!ev) return Astro.redirect('/esemenyek');
const heroStyle = ev.accentColor ? `--color-accent: ${ev.accentColor}` : undefined;
const coverUrl = ev.cover ? urlForImage(ev.cover).width(1600).height(720).fit('crop').url() : null;

// OG-leírás: dátum + helyszín tömör összefoglalója.
const dateLabel = ev.startsAt
  ? new Intl.DateTimeFormat('hu-HU', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }).format(new Date(ev.startsAt))
  : '';
const metaDescription = [dateLabel, ev.location?.name].filter(Boolean).join(' · ') || undefined;

// schema.org Event strukturált adat (Google "Esemény" rich result).
const eventJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: ev.title,
  ...(ev.startsAt ? { startDate: ev.startsAt } : {}),
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  ...(coverUrl ? { image: [coverUrl] } : {}),
  ...(ev.location?.name
    ? { location: { '@type': 'Place', name: ev.location.name, address: ev.location.address || ev.location.name } }
    : {}),
  ...(ev.ticketUrl
    ? { offers: { '@type': 'Offer', url: ev.ticketUrl, availability: 'https://schema.org/InStock' } }
    : {}),
  organizer: { '@type': 'Organization', name: 'Slam Poetry Magyarország', url: 'https://slampoetry.hu' },
  url: new URL(`/esemenyek/${ev.slug}`, Astro.site).href,
};
---
<BaseLayout title={ev.title} description={metaDescription} image={coverUrl ?? undefined} ogType="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(eventJsonLd)} />
  <section class="relative overflow-hidden bg-ink text-surface" style={heroStyle}>
    {coverUrl && <img src={coverUrl} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover opacity-40" />}
    {coverUrl && <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/70 to-ink/40"></div>}
    <div class="relative z-10 mx-auto max-w-5xl px-4 py-20 md:py-28">
      <p class="mb-3 inline-flex items-center gap-2 pt-1 text-xs uppercase leading-[1.6] tracking-[0.2em] text-accent">
        <span class="h-px w-8 bg-accent"></span><span class="inline-block">Esemény</span>
      </p>
      <h1 class="max-w-3xl font-display text-5xl leading-[0.9] md:text-7xl">{ev.title}</h1>
    </div>
  </section>

  <div class="mx-auto max-w-3xl px-4 py-12">
    <EventNeonCard
      startsAt={ev.startsAt}
      locationName={ev.location?.name}
      locationAddress={ev.location?.address}
      mapUrl={ev.location?.mapUrl}
      facebookEventUrl={ev.facebookEventUrl}
    />

    {ev.ticketUrl && (
      <a href={ev.ticketUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block rounded-lg bg-accent px-6 py-3 font-semibold text-ink transition hover:opacity-90">Jegyek →</a>
    )}

    {ev.description && <div class="mt-10"><RichText value={ev.description} /></div>}

    {ev.registrationEnabled && <RegistrationForm eventSlug={ev.slug} deadline={ev.registrationDeadline} />}

    {ev.performers?.length && (
      <div class="mt-12">
        <h2 class="mb-4 font-display text-2xl">Fellépők</h2>
        <div class="grid grid-cols-2 gap-6 sm:grid-cols-3">
          {ev.performers.map((p) => (
            <a href={`/slammerek/${p.slug}`} class="group">
              <div class="aspect-[3/4] overflow-hidden rounded-lg bg-ink/5">
                {p.photo && <img src={urlForImage(p.photo).width(300).height(400).url()} alt={p.name} loading="lazy" decoding="async" width="300" height="400" class="h-full w-full object-cover transition group-hover:scale-105" />}
              </div>
              <p class="mt-2 font-display group-hover:text-accent">{p.name}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
