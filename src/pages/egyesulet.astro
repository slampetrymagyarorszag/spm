---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import RichText from '../components/RichText.astro';
import ContactForm from '../components/ContactForm.astro';
import { getPageBySlug } from '../sanity/lib/api';
import { sanityClient } from 'sanity:client';
const page = await getPageBySlug(sanityClient, 'egyesulet');
---
<BaseLayout title={page?.title ?? 'Egyesület'}>
  <PageHero label="Rólunk" title={page?.title ?? 'Egyesület'} lead={page?.lead} object="/hero-beer.png" objectAlt="" />
  <div class="mx-auto max-w-3xl px-4 py-12">
    {page?.body ? <RichText value={page.body} /> : <p class="text-muted">Ez az oldal hamarosan elkészül. (Hozz létre egy „Oldal" dokumentumot „egyesulet" slug-gal a Studióban.)</p>}
  </div>

  <section class="bg-ink text-surface">
    <div class="mx-auto max-w-3xl px-4 py-16">
      <p class="mb-2 inline-flex items-center gap-2 pt-1 text-xs uppercase leading-[1.6] tracking-[0.2em] text-accent">
        <span class="h-px w-8 bg-accent"></span><span class="inline-block">Írj nekünk</span>
      </p>
      <h2 class="font-display text-3xl md:text-5xl leading-[0.95]">Lépj kapcsolatba velünk</h2>
      <p class="mt-3 max-w-xl text-surface/75">Kérdésed van az egyesülettel kapcsolatban? Írj, és hamarosan válaszolunk.</p>
      <div class="mt-8 [&_input]:bg-surface [&_textarea]:bg-surface [&_input]:text-ink [&_textarea]:text-ink">
        <ContactForm dept="media" />
      </div>
    </div>
  </section>
</BaseLayout>
