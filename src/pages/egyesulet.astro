---
import BaseLayout from '../layouts/BaseLayout.astro';
import Association from '../components/pages/Association.astro';
import { urlForImage } from '../sanity/lib/image';
import { getPageBySlug } from '../sanity/lib/api';
import { sanityClient } from 'sanity:client';
const page = await getPageBySlug(sanityClient, 'egyesulet');
const seoDescription = page?.seo?.metaDescription || page?.lead;
const seoImage = page?.seo?.shareImage ? urlForImage(page.seo.shareImage).width(1200).height(630).fit('crop').url() : undefined;
---
<BaseLayout title={page?.seo?.metaTitle ?? page?.title ?? 'Egyesület'} description={seoDescription} image={seoImage}>
  <Association page={page} lang="hu" />
</BaseLayout>
