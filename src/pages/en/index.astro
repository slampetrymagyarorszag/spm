---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Home from "../../components/pages/Home.astro";
import { getEvents, getSlammers, getFeaturedSlammers, getPosts, getSiteSettings } from "../../sanity/lib/api";
import { splitEvents } from "../../sanity/lib/events";
import { urlForImage } from "../../sanity/lib/image";
import { sanityClient } from "sanity:client";

const [events, slammers, featured, posts, settings] = await Promise.all([
  getEvents(sanityClient),
  getSlammers(sanityClient),
  getFeaturedSlammers(sanityClient),
  getPosts(sanityClient),
  getSiteSettings(sanityClient),
]);
const siteSettings = settings ?? { title: 'Slam Poetry Magyarország' };
const upcoming = splitEvents(events).upcoming.slice(0, 4);
// Kiemelt slammerek elöl (CMS „Kiemelt a főoldalon" + sorrend), mögöttük a többiek
// név szerint feltöltve — így a galéria mindig tele van, de a kiemeltek vezetnek.
const featuredIds = new Set(featured.map((s) => s._id));
const slammerSource = [...featured, ...slammers.filter((s) => !featuredIds.has(s._id))];
// Minden kiemelt slammer férjen el (ha 10-nél több van), de ne legyen abszurd sok panel.
const galleryLimit = Math.min(Math.max(featured.length, 10), 14);
const featuredSlammers = slammerSource
  .filter((s) => s.photo)
  .slice(0, galleryLimit)
  .map((s) => ({
    name: s.name,
    slug: s.slug,
    hometown: s.hometown,
    photoUrl: s.photo ? urlForImage(s.photo).width(500).height(720).fit('crop').url() : undefined,
  }));
const latestPosts = posts.slice(0, 12);

const s = siteSettings.social ?? {};
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Slam Poetry Magyarország',
  url: Astro.site?.href ?? 'https://slampoetry.hu',
  logo: new URL('/og-default.jpg', Astro.site).href,
  sameAs: [s.facebook, s.instagram, s.youtube, s.tiktok].filter(Boolean),
};
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Slam Poetry Magyarország',
  url: Astro.site?.href ?? 'https://slampoetry.hu',
};
---
<BaseLayout>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify([orgJsonLd, siteJsonLd])} />
  <Home
    upcoming={upcoming}
    featuredSlammers={featuredSlammers}
    latestPosts={latestPosts}
    siteSettings={siteSettings}
    lang="en"
  />
</BaseLayout>
