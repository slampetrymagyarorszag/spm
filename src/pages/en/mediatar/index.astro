---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MediaLibrary from '../../../components/pages/MediaLibrary.astro';
import { getMedia, getMediaConfig } from '../../../sanity/lib/api';
import { fetchChannelUploads, fetchPlaylistItems, parsePlaylistId } from '../../../lib/youtube';
import { sanityClient } from 'sanity:client';

const env = import.meta.env;
const apiKey = env.YOUTUBE_API_KEY ?? process.env.YOUTUBE_API_KEY;

const [media, config, videos] = await Promise.all([
  getMedia(sanityClient),
  getMediaConfig(sanityClient),
  fetchChannelUploads({
    apiKey,
    channelId: env.YOUTUBE_CHANNEL_ID ?? process.env.YOUTUBE_CHANNEL_ID,
    handle: env.YOUTUBE_CHANNEL_HANDLE ?? process.env.YOUTUBE_CHANNEL_HANDLE,
    max: 9,
  }),
]);

// Lejátszási listák két forrásból: (1) a médiatár „lejátszási lista" elemei, és
// (2) a beállításokban megadott listák. Mindkettő elfogad teljes URL-t vagy nyers ID-t.
const playlistDefs = [
  ...media.filter((m) => m.kind === 'playlist').map((m) => ({ title: m.title, id: parsePlaylistId(m.playlistUrl) })),
  ...(config.youtubePlaylists ?? []).map((p) => ({ title: p.title || 'Lejátszási lista', id: parsePlaylistId(p.playlistId) })),
].filter((p) => p.id);
const playlists = await Promise.all(
  playlistDefs.map(async (p) => ({
    title: p.title || 'Lejátszási lista',
    videos: await fetchPlaylistItems(apiKey, p.id!, 6),
  })),
);
// A galéria-rácsban a playlist-elemek ne jelenjenek meg (külön szekcióként jönnek).
const galleryMedia = media.filter((m) => m.kind !== 'playlist');
const downloads = (config.downloads ?? []).filter((d) => d.fileUrl || d.url);
const hasAny = galleryMedia.length > 0 || videos.length > 0 || playlists.some((p) => p.videos.length) || downloads.length > 0;
---
<BaseLayout title="Media library">
  <MediaLibrary videos={videos} playlists={playlists} galleryMedia={galleryMedia} downloads={downloads} hasAny={hasAny} lang="en" />
</BaseLayout>
